<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - StreamHub</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="bg-dark text-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-black border-bottom border-secondary">
        <div class="container">
            <a class="navbar-brand fw-bold text-danger" asp-controller="Home" asp-action="Index">StreamHub</a>
            <div class="d-flex ms-auto">
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <a class="btn btn-outline-light me-2" asp-controller="Video" asp-action="Upload">Upload</a>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                        <button type="submit" class="btn btn-outline-danger">Log out (@User.Identity.Name)</button>
                    </form>
                }
                else
                {
                    <a class="btn btn-outline-light me-2" asp-controller="Account" asp-action="Login">Log in</a>
                    <a class="btn btn-danger" asp-controller="Account" asp-action="Register">Sign up</a>
                }
            </div>
        </div>
    </nav>

    <main class="container py-4">
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
