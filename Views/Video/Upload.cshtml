@model UploadVideoViewModel
@{
    ViewData["Title"] = "Upload video";
}
<div class="row justify-content-center">
    <div class="col-md-6">
        <h2 class="mb-4">Upload a video</h2>
        <div asp-validation-summary="All" class="text-danger"></div>
        <form asp-controller="Video" asp-action="Upload" method="post" enctype="multipart/form-data">
            <div class="mb-3">
                <label class="form-label">Title</label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Description</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>
            <div class="mb-3">
                <label class="form-label">Category</label>
                <select asp-for="Category" class="form-select">
                    <option>Movies</option>
                    <option>Series</option>
                    <option>Documentary</option>
                    <option>Music</option>
                    <option>Education</option>
                    <option>Other</option>
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label">Video file (.mp4, .webm, .ogg &mdash; max 300MB)</label>
                <input asp-for="VideoFile" type="file" class="form-control" accept="video/mp4,video/webm,video/ogg" />
                <span asp-validation-for="VideoFile" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Thumbnail (optional)</label>
                <input asp-for="ThumbnailFile" type="file" class="form-control" accept="image/*" />
            </div>
            <button type="submit" class="btn btn-danger w-100">Upload</button>
        </form>
    </div>
</div>
