@model Video
@{
    ViewData["Title"] = Model.Title;
    var isAuthenticated = User.Identity != null && User.Identity.IsAuthenticated;
}
<div class="row">
    <div class="col-lg-8">
        <video id="player" class="w-100 bg-black" style="max-height:70vh;" controls preload="metadata" src="@Model.VideoPath"></video>
        <h2 class="mt-3">@Model.Title</h2>
        <p class="text-muted">@Model.Category &middot; @Model.Views views &middot; uploaded @Model.UploadDate.ToString("MMM d, yyyy")</p>
        <p>@Model.Description</p>
    </div>
</div>

@section Scripts {
<script>
    const video = document.getElementById('player');
    const startPosition = @Html.Raw(ViewBag.StartPosition.ToString(System.Globalization.CultureInfo.InvariantCulture));
    const videoId = @Model.Id;
    const isAuthenticated = @(isAuthenticated ? "true" : "false");

    video.addEventListener('loadedmetadata', () => {
        if (startPosition > 0 && startPosition < video.duration - 5) {
            video.currentTime = startPosition;
        }
    });

    function saveProgress() {
        if (!isAuthenticated) return;
        fetch('/Video/SaveProgress', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: `videoId=${videoId}&position=${video.currentTime}`
        });
    }

    if (isAuthenticated) {
        setInterval(() => {
            if (!video.paused) saveProgress();
        }, 10000);

        video.addEventListener('pause', saveProgress);
        window.addEventListener('beforeunload', saveProgress);
    }
</script>
}
